;;; test_sub_decay.blisp — P1: sub_threat decay and CGRD submissions

(define pass-count 0)
(define fail-count 0)
(define assert-eq (lambda (label actual expected)
  (if (same actual expected)
    (progn (define pass-count (+ pass-count 1))
           (print (str-cat "  PASS: " label)))
    (progn (define fail-count (+ fail-count 1))
           (print (str-cat "  FAIL: " label " got=" actual " want=" expected))))))

(print "=== SUB_THREAT DECAY + CGRD SUBMISSIONS ===")

;; ── Setup states ────────────────────────────────────────────────────
(define st-mnt (state-set-ori
  (state-add-con (state-add-con init-state CON-ME-LE+-OP-TO) CON-ME-LE--OP-TO)
  "level" "ME_OVER"))
(define st-sctr (state-set-ori
  (state-add-con init-state CON-ME-AR+-OP-TO)
  "level" "ME_OVER"))
(define st-cgrd (state-add-con (state-add-con init-state CON-ME-LE+-OP-TO) CON-ME-LE--OP-TO))

;; ── 1. Decay on PASS from MNT ──────────────────────────────────────

(define gm1 (GAME-MEM 0 2 "A" 1))
(define r1 (resolve st-mnt gm1 "PASS" "PASS"))
(assert-eq "decay: MNT PASS 2→1" (GET (GET r1 :gmem) :sub_threat) 1)

(define r2 (resolve st-mnt (GET r1 :gmem) "PASS" "PASS"))
(assert-eq "decay: MNT PASS 1→0" (GET (GET r2 :gmem) :sub_threat) 0)

(define r3 (resolve st-mnt (GET r2 :gmem) "PASS" "PASS"))
(assert-eq "decay: MNT PASS 0→0 floor" (GET (GET r3 :gmem) :sub_threat) 0)

;; ── 2. Decay on control MOR (not submission) ───────────────────────

(define gm2 (GAME-MEM 0 2 "A" 1))
(define r4 (resolve st-mnt gm2 "mnt_pressure" "PASS"))
(assert-eq "decay: pressure 2→1" (GET (GET r4 :gmem) :sub_threat) 1)

;; ── 3. Submission MOR still increments despite prior decay ──────────

(define gm3 (GAME-MEM 0 1 "A" 1))
(define r5 (resolve st-mnt gm3 "mnt_sub" "PASS"))
(assert-eq "increment: sub 1→2" (GET (GET r5 :gmem) :sub_threat) 2)

;; ── 4. Sub_threat=3 still triggers submission ───────────────────────

(define gm4 (GAME-MEM 0 2 "A" 1))
(define r6 (resolve st-mnt gm4 "mnt_sub" "PASS"))
(assert-eq "sub=3 triggers" (GET (GET r6 :gmem) :sub_threat) 3)

;; ── 5. Decay from SCTR ─────────────────────────────────────────────

(define gm5 (GAME-MEM 0 2 "A" 1))
(define r7 (resolve st-sctr gm5 "PASS" "PASS"))
(assert-eq "decay: SCTR PASS 2→1" (GET (GET r7 :gmem) :sub_threat) 1)

;; ── 6. Position change still resets to 0 ────────────────────────────

(define gm6 (GAME-MEM 0 2 "A" 1))
(define r8 (resolve st-sctr gm6 "sctr_mount" "PASS"))
(assert-eq "reset: pos change 2→0" (GET (GET r8 :gmem) :sub_threat) 0)

;; ── 7. CGRD triangle accumulates sub_threat ─────────────────────────

(define gm7 (GAME-MEM 0 0 "A" 1))
(define c1 (resolve st-cgrd gm7 "triangle" "PASS"))
(assert-eq "CGRD triangle: 0→1" (GET (GET c1 :gmem) :sub_threat) 1)

(define c2 (resolve st-cgrd (GET c1 :gmem) "triangle" "PASS"))
(assert-eq "CGRD triangle: 1→2" (GET (GET c2 :gmem) :sub_threat) 2)

(define c3 (resolve st-cgrd (GET c2 :gmem) "triangle" "PASS"))
(assert-eq "CGRD triangle: 2→3 sub" (GET (GET c3 :gmem) :sub_threat) 3)

;; ── 8. CGRD non-submission does NOT increment ───────────────────────

(define gm8 (GAME-MEM 0 0 "A" 1))
(define c4 (resolve st-cgrd gm8 "hip_bump" "PASS"))
(assert-eq "CGRD sweep: no sub" (GET (GET c4 :gmem) :sub_threat) 0)

;; ── 9. CGRD sub_threat decays on PASS ───────────────────────────────

(define gm9 (GAME-MEM 0 2 "A" 1))
(define c5 (resolve st-cgrd gm9 "PASS" "PASS"))
(assert-eq "CGRD PASS: decay 2→1" (GET (GET c5 :gmem) :sub_threat) 1)

;; ── 10. Interleaved sub/PASS shows accumulate-decay pattern ─────────

(define gm10 (GAME-MEM 0 0 "A" 1))
(define i1 (resolve st-mnt gm10 "mnt_sub" "PASS"))
(assert-eq "interleave: sub 0→1" (GET (GET i1 :gmem) :sub_threat) 1)

(define i2 (resolve st-mnt (GET i1 :gmem) "PASS" "PASS"))
(assert-eq "interleave: PASS 1→0" (GET (GET i2 :gmem) :sub_threat) 0)

(define i3 (resolve st-mnt (GET i2 :gmem) "mnt_sub" "PASS"))
(assert-eq "interleave: sub 0→1" (GET (GET i3 :gmem) :sub_threat) 1)

(define i4 (resolve st-mnt (GET i3 :gmem) "mnt_sub" "PASS"))
(assert-eq "interleave: sub 1→2" (GET (GET i4 :gmem) :sub_threat) 2)

(define i5 (resolve st-mnt (GET i4 :gmem) "mnt_sub" "PASS"))
(assert-eq "interleave: sub 2→3" (GET (GET i5 :gmem) :sub_threat) 3)

(print (str-cat "=== SUB DECAY: " pass-count " passed, " fail-count " failed ==="))
