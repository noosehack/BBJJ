;;; test_contests.blisp — Contest resolution determinism
;;; Invariant: DEL vs MAINTAIN → higher priority wins. Tie → CON preserved.

(define PASS-COUNT 0)
(define FAIL-COUNT 0)

(define assert-eq (lambda (label actual expected)
  (if (same actual expected)
    (progn (print (str-cat "  PASS: " label)) (define PASS-COUNT (+ PASS-COUNT 1)))
    (progn (print (str-cat "  FAIL: " label " got=" actual " want=" expected))
           (define FAIL-COUNT (+ FAIL-COUNT 1))))))

(print "=== CONTEST RESOLUTION ===")

;; Setup: OGRD state (Me.Le→Op contact)
(define st-ogrd (state-add-con init-state CON-ME-LE-OP))

;; ogrd_sweep DELs CON-ME-LE-OP (op2, burst=2, cost=2)
;; ogrd_retain MAINTAINs CON-ME-LE-OP (op0, burst=3, cost=1)
;; Retain always outprioritizes sweep:
;;   A sweep: max pri = burst(2) + init(1) - diff(1) = 2
;;   B retain: min pri = burst(3) + init(0) - diff(0) = 3
;; B wins contest → DEL blocked → leg stays
(define gm-a-init (GAME-MEM 0 0 "A" 1))
(define r1 (resolve st-ogrd gm-a-init "ogrd_sweep" "ogrd_retain"))
(assert-eq "retain beats sweep: leg preserved" (state-has-con (GET r1 :state) CON-ME-LE-OP) true)

;; Uncontested DEL: A sweeps, B passes (no MAINTAIN)
;; DEL succeeds freely when no one is defending
(define r2 (resolve st-ogrd gm-a-init "ogrd_sweep" "PASS"))
(assert-eq "uncontested DEL: leg gone" (state-has-con (GET r2 :state) CON-ME-LE-OP) false)

;; del-contested function: triangle MAINTAINs both legs
(define del-le (OP-DEL CON-ME-LE+-OP-TO))
(define tri-mor (mor-lookup "triangle"))
(assert-eq "del-contested: triangle blocks LE+" (del-contested del-le tri-mor) true)

(define del-ar (OP-DEL CON-ME-AR+-OP-TO))
(assert-eq "del-contested: triangle ignores AR+" (del-contested del-ar tri-mor) false)

;; mor-maintains: check specific CONs
(define retain-mor (mor-lookup "ogrd_retain"))
(assert-eq "mor-maintains: retain guards LE-OP" (mor-maintains retain-mor CON-ME-LE-OP) true)
(assert-eq "mor-maintains: retain ignores LE+-TO" (mor-maintains retain-mor CON-ME-LE+-OP-TO) false)

;; Initiative: whoever wins more contests gets initiative
;; In the contested case (r1), B won the contest → initiative goes to B
;; But count-contest-wins only checks op0/op1, and sweep's DEL is on op2
;; So wins_a=0, wins_b=0 → no change → stays A
(assert-eq "contest init unchanged" (GET (GET r1 :gmem) :initiative) "A")

;; Priority calculation verification
(define sweep (mor-lookup "ogrd_sweep"))
(define retain (mor-lookup "ogrd_retain"))
(define pri-a (calc-priority sweep gm-a-init "OGRD" "A"))
(define pri-b (calc-priority retain gm-a-init "OGRD" "B"))
(assert-eq "sweep priority" pri-a 2)
(assert-eq "retain priority" pri-b 3)

;; Verify contest outcome is deterministic
(define r3 (resolve st-ogrd gm-a-init "ogrd_sweep" "ogrd_retain"))
(assert-eq "deterministic" (same (GET r1 :state) (GET r3 :state)) true)

(print (str-cat "=== CONTESTS: " PASS-COUNT " passed, " FAIL-COUNT " failed ==="))
