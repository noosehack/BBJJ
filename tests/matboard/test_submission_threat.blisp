;;; test_submission_threat.blisp — sub_threat accumulates from MAINTAIN-only MORs
;;; Invariant: Legal submission MOR from offense increments sub_threat
;;; even when no ADD/DEL occurs (MAINTAIN-only).

(define PASS-COUNT 0)
(define FAIL-COUNT 0)

(define assert-eq (lambda (label actual expected)
  (if (same actual expected)
    (progn (print (str-cat "  PASS: " label)) (define PASS-COUNT (+ PASS-COUNT 1)))
    (progn (print (str-cat "  FAIL: " label " got=" actual " want=" expected))
           (define FAIL-COUNT (+ FAIL-COUNT 1))))))

(print "=== SUBMISSION THREAT ACCUMULATION ===")

;; Build MNT state
(define st-mnt (state-set-ori
  (state-add-con
    (state-add-con init-state CON-ME-LE+-OP-TO)
    CON-ME-LE--OP-TO)
  "level" "ME_OVER"))
(assert-eq "setup: MNT" (classify st-mnt) "MNT")

;; mnt_sub is MAINTAIN-only: no state change expected
(define gm0 (GAME-MEM 0 0 "A" 1))
(define r1 (resolve st-mnt gm0 "mnt_sub" "PASS"))
(assert-eq "state unchanged" (same (GET r1 :state) st-mnt) true)
(assert-eq "sub_threat 0→1" (GET (GET r1 :gmem) :sub_threat) 1)

;; Second sub attempt
(define r2 (resolve (GET r1 :state) (GET r1 :gmem) "mnt_sub" "PASS"))
(assert-eq "sub_threat 1→2" (GET (GET r2 :gmem) :sub_threat) 2)

;; Third sub attempt → win
(define r3 (resolve (GET r2 :state) (GET r2 :gmem) "mnt_sub" "PASS"))
(assert-eq "sub_threat 2→3" (GET (GET r3 :gmem) :sub_threat) 3)
(assert-eq "submission win"  (if (>= (GET (GET r3 :gmem) :sub_threat) 3) true false) true)

;; Submission from CGRD now increments sub_threat (P1.2: CGRD offensive for subs)
(define gm-def (GAME-MEM 0 0 "A" 1))
(define r-cgrd (resolve
  (state-add-con (state-add-con init-state CON-ME-LE+-OP-TO) CON-ME-LE--OP-TO)
  gm-def "triangle" "PASS"))
(assert-eq "triangle from CGRD: sub=1" (GET (GET r-cgrd :gmem) :sub_threat) 1)

;; Sub_threat resets on position change away from offense
(define gm-sub1 (GAME-MEM 0 1 "A" 1))
(define st-sctr (state-set-ori (state-add-con init-state CON-ME-AR+-OP-TO) "level" "ME_OVER"))
(define r-pos-change (resolve st-sctr gm-sub1 "sctr_mount" "PASS"))
(assert-eq "sub resets on pos change" (GET (GET r-pos-change :gmem) :sub_threat) 0)

(print (str-cat "=== SUBMISSION THREAT: " PASS-COUNT " passed, " FAIL-COUNT " failed ==="))
